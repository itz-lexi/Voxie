<Window x:Class="Voxie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voxie" Height="790" Width="1240" MinHeight="680" MinWidth="980"
        Icon="/Assets/AppIcon.ico" Background="#0F1011" FontFamily="Segoe UI"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="Pink" Color="#FF7AD9" />
        <SolidColorBrush x:Key="Blue" Color="#73D7FF" />
        <SolidColorBrush x:Key="Muted" Color="#A8ADB2" />
        <LinearGradientBrush x:Key="Primary" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#8EDFFF" Offset="0" />
            <GradientStop Color="#FF8CDD" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="Header" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#17191B" Offset="0" />
            <GradientStop Color="#211B27" Offset="0.52" />
            <GradientStop Color="#151D23" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="Pride" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#73D7FF" Offset="0" />
            <GradientStop Color="#73D7FF" Offset="0.2" />
            <GradientStop Color="#FF7AD9" Offset="0.2" />
            <GradientStop Color="#FF7AD9" Offset="0.4" />
            <GradientStop Color="#F7F7F7" Offset="0.4" />
            <GradientStop Color="#F7F7F7" Offset="0.6" />
            <GradientStop Color="#FF7AD9" Offset="0.6" />
            <GradientStop Color="#FF7AD9" Offset="0.8" />
            <GradientStop Color="#73D7FF" Offset="0.8" />
            <GradientStop Color="#73D7FF" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrideHover" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#A5E7FF" Offset="0" />
            <GradientStop Color="#FFA8E6" Offset="0.45" />
            <GradientStop Color="#D5B6FF" Offset="1" />
        </LinearGradientBrush>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="13,6" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="Background" Value="#242628" />
            <Setter Property="Foreground" Value="#F3F3F3" />
            <Setter Property="BorderBrush" Value="#3A3D40" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#303438" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Primary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Primary}" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Background" Value="#202326" />
            <Setter Property="Foreground" Value="#EEF2F0" />
            <Setter Property="CaretBrush" Value="{StaticResource Pink}" />
            <Setter Property="BorderBrush" Value="#3A3F43" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxChrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxChrome" Property="Background" Value="#252A2D" />
                                <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="#6B747A" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="{StaticResource Pink}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#EEF2F0" />
            <Setter Property="Background" Value="#202326" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#2E2635" />
                                <Setter Property="Foreground" Value="#FFEAF8" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#34283D" />
                                <Setter Property="Foreground" Value="#FFEAF8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Background" Value="#202326" />
            <Setter Property="Foreground" Value="#EEF2F0" />
            <Setter Property="BorderBrush" Value="#3A3F43" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboChrome" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="30" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1" x:Name="ArrowHitbox" Background="#282D31" BorderBrush="#3A3F43"
                                                        BorderThickness="1,0,0,0" CornerRadius="0,8,8,0">
                                                    <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="{StaticResource Pink}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboChrome" Property="BorderBrush" Value="#6B747A" />
                                                <Setter TargetName="ArrowHitbox" Property="Background" Value="#32383D" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ComboChrome" Property="BorderBrush" Value="{StaticResource Pink}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <TextBlock Margin="{TemplateBinding Padding}" VerticalAlignment="Center" IsHitTestVisible="False"
                                       Foreground="{TemplateBinding Foreground}" TextTrimming="CharacterEllipsis">
                                <TextBlock.Text>
                                    <PriorityBinding>
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="SelectionBoxItem.Name" />
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="SelectionBoxItem" />
                                    </PriorityBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom">
                                <Border Background="#202326" BorderBrush="{StaticResource Pink}" BorderThickness="1"
                                        CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="280">
                                    <ScrollViewer Margin="0,5"><ItemsPresenter /></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Height" Value="24" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="{StaticResource Primary}" CornerRadius="3" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18" Height="18">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="SliderThumb" Fill="#F8F8F8" Stroke="{StaticResource Pink}" StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="7" Opacity="0.35" ShadowDepth="0" Color="#FF7AD9" />
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="SliderThumb" Property="Fill" Value="{StaticResource Blue}" />
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="SliderThumb" Property="Fill" Value="{StaticResource Pink}" />
                                                        <Setter TargetName="SliderThumb" Property="Stroke" Value="#FFFFFF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="#34393D" CornerRadius="3" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EEF2F0" />
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10" />
            <Setter Property="Background" Value="#24282B" />
            <Setter Property="Foreground" Value="{StaticResource Primary}" />
            <Setter Property="BorderBrush" Value="#3A3F43" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                            <Grid x:Name="PART_Track" ClipToBounds="True">
                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                        HorizontalAlignment="Left" CornerRadius="4" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="14,10" />
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#171A1C" />
            <Setter Property="BorderBrush" Value="#2E3337" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="InvisibleScrollButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernScrollThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbChrome" Margin="3" Background="#5B666C" BorderBrush="#728087"
                                BorderThickness="1" CornerRadius="6">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Direction="270" Opacity="0.18" ShadowDepth="1" Color="#000000" />
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource Pride}" />
                                <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{StaticResource Pink}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource PrideHover}" />
                                <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#101213" />
            <Setter Property="Width" Value="14" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="{TemplateBinding Width}" Background="Transparent">
                            <Border Margin="4,2" Background="#1D2022" BorderBrush="#2C3135" BorderThickness="1" CornerRadius="7" />
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource InvisibleScrollButton}" Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource InvisibleScrollButton}" Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="14" />
                    <Setter Property="Margin" Value="0,8,0,0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Height="{TemplateBinding Height}" Background="Transparent">
                                    <Border Margin="2,4" Background="#1D2022" BorderBrush="#2C3135" BorderThickness="1" CornerRadius="7" />
                                    <Track x:Name="PART_Track" Orientation="Horizontal">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource InvisibleScrollButton}" Command="ScrollBar.PageLeftCommand" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ModernScrollThumb}" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource InvisibleScrollButton}" Command="ScrollBar.PageRightCommand" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#141617" BorderBrush="#272B2E" BorderThickness="0,0,1,0">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="VOXIE" Foreground="{StaticResource Pink}" FontWeight="Bold" FontSize="20" />
                    <TextBlock Text="STT STUDIO" Foreground="#F8F8F8" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="voice, captured clearly" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,3,0,24" />
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource NavButton}" Content="Transcript" Click="ShowTranscript_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Art gallery" Click="ShowGallery_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Settings" Click="ShowSettings_Click" />
                </StackPanel>
                <StackPanel Grid.Row="3">
                    <Border x:Name="SidebarUpdatePrompt" Visibility="Collapsed" Background="#2B2031"
                            BorderBrush="{StaticResource Blue}" BorderThickness="1" CornerRadius="10"
                            Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="VOXIE UPDATE READY" Foreground="{StaticResource Blue}" FontSize="10" FontWeight="Bold" />
                            <TextBlock x:Name="SidebarUpdateText" Text="A newer version is ready to install."
                                       Foreground="#F3F3F3" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,8" />
                            <Button x:Name="SidebarInstallUpdateButton" Style="{StaticResource PrimaryButton}"
                                    Margin="0" Padding="8,5" Content="Install update" Click="SidebarInstallUpdate_Click" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="ModelDownloadPrompt" Background="#2A1D2A" BorderBrush="{StaticResource Pink}"
                            BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="WHISPER MODEL NEEDED" Foreground="{StaticResource Pink}" FontSize="10" FontWeight="Bold" />
                            <TextBlock Text="Download the local speech model before recording."
                                       Foreground="#F3F3F3" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,8" />
                            <Button x:Name="SidebarDownloadModelButton" Style="{StaticResource PrimaryButton}"
                                    Margin="0" Padding="8,5" Content="Download base.en" Click="DownloadModel_Click" />
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#2E3337" BorderThickness="1" CornerRadius="10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="ENGINE STATUS" Foreground="{StaticResource Blue}" FontSize="10" FontWeight="Bold" />
                            <TextBlock x:Name="EngineStatusText" Text="Checking local Whisper model..." Foreground="#D7DADC" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="86" />
                <RowDefinition Height="*" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>
            <Border Background="{StaticResource Header}" BorderBrush="#2A2D30" BorderThickness="0,0,0,1">
                <Grid Margin="24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource Pride}" CornerRadius="3" />
                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                        <TextBlock x:Name="PageTitle" Text="Transcript workspace" Foreground="#FFFFFF" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock x:Name="PageSubtitle" Text="Capture live phrases with a button or global shortcut." Foreground="{StaticResource Muted}" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
            <Grid x:Name="TranscriptPage" Grid.Row="1" Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="LIVE CAPTURE" Foreground="{StaticResource Pink}" FontWeight="Bold" FontSize="11" />
                            <TextBlock x:Name="CaptureStatusText" Text="Shortcut ready" Foreground="#FFFFFF" FontSize="19" FontWeight="SemiBold" Margin="0,4,0,0" />
                            <TextBlock x:Name="CaptureHintText" Text="Press F8 to record a phrase." Foreground="{StaticResource Muted}" Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="StartRecordingButton" Style="{StaticResource PrimaryButton}" Content="Start recording" Click="StartRecording_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,9">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="Repeat in chatbox" Click="RepeatChatbox_Click" />
                            <Button Content="Copy" Click="CopyTranscript_Click" />
                            <Button Content="Clear" Click="ClearTranscript_Click" />
                        </StackPanel>
                        <TextBlock Text="Transcript" Foreground="#FFFFFF" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </DockPanel>
                    <TextBox x:Name="TranscriptTextBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="14" Text="Your transcript will appear here after you record a phrase." />
                </Grid>
            </Grid>
            <Grid x:Name="GalleryPage" Grid.Row="1" Margin="22" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="COMMISSIONED ART" Foreground="{StaticResource Pink}" FontWeight="Bold" FontSize="11" />
                        <TextBlock Text="A read-only showcase of emotes, banners, and illustrations shared by Lexi." Foreground="#FFFFFF" FontSize="17" Margin="0,5,0,0" />
                    </StackPanel>
                </Border>
                <ScrollViewer x:Name="GalleryScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              PanningMode="VerticalOnly" Padding="0,0,8,0">
                    <StackPanel x:Name="GalleryPanel" HorizontalAlignment="Left" VerticalAlignment="Top" />
                </ScrollViewer>
            </Grid>
            <Grid x:Name="SettingsPage" Grid.Row="1" Margin="22" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource Card}" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="TRANSCRIPTION SETTINGS" Foreground="{StaticResource Pink}" FontWeight="Bold" FontSize="11" />
                        <TextBlock Text="Local Whisper preferences" Foreground="#FFFFFF" FontSize="18" FontWeight="SemiBold" Margin="0,5,0,16" />
                        <TextBlock Text="Audio source" Foreground="{StaticResource Muted}" />
                        <Grid Margin="0,5,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="AudioSourceComboBox" DisplayMemberPath="Name"
                                      SelectionChanged="AudioSourceComboBox_SelectionChanged" />
                            <Button Grid.Column="1" Content="Refresh devices" Click="RefreshAudioDevices_Click"
                                    Margin="8,0,0,0" />
                        </Grid>
                        <TextBlock Text="Microphone level" Foreground="{StaticResource Muted}" FontSize="11" />
                        <ProgressBar x:Name="MicrophoneLevelMeter" Minimum="0" Maximum="100" Margin="0,5,0,4" />
                        <TextBlock x:Name="MicrophoneLevelHint" Text="Open Settings to preview the selected microphone."
                                   Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,12" />
                        <TextBlock Text="Language" Foreground="{StaticResource Muted}" />
                        <ComboBox x:Name="LanguageComboBox" Margin="0,5,0,12">
                            <ComboBoxItem Content="English" />
                            <ComboBoxItem Content="Auto-detect" />
                        </ComboBox>
                        <TextBlock Text="STT model" Foreground="{StaticResource Muted}" />
                        <ComboBox x:Name="ModelComboBox" Margin="0,5,0,12">
                            <ComboBoxItem Content="Whisper base.en (local CPU)" />
                        </ComboBox>
                        <CheckBox x:Name="AutoCopyCheckBox" Content="Copy transcript automatically when capture stops" Margin="0,3,0,16" />
                        <TextBlock Text="Phrase activation key" Foreground="{StaticResource Muted}" />
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,12">
                            <Border Background="#202326" BorderBrush="#3A3F43" BorderThickness="1" CornerRadius="8"
                                    Padding="12,7" Margin="0,0,8,0" MinWidth="90">
                                <TextBlock x:Name="ActivationKeyText" Text="F8" Foreground="#EEF2F0" FontWeight="SemiBold" />
                            </Border>
                            <Button x:Name="ChangeKeybindButton" Content="Change keybind" Click="ChangeKeybind_Click" />
                            <Button x:Name="CancelKeybindButton" Content="Cancel" Click="CancelKeybind_Click"
                                    Visibility="Collapsed" />
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource Muted}">
                            <Run Text="Silence before phrase completes: " />
                            <Run x:Name="SilenceDurationText" Text="5.0 seconds" />
                        </TextBlock>
                        <Slider x:Name="SilenceDurationSlider" Minimum="1" Maximum="12" Value="5"
                                IsSnapToTickEnabled="False" Margin="0,6,0,5" ValueChanged="SilenceDurationSlider_ValueChanged" />
                        <TextBlock Text="Map a VR controller button to the selected keyboard key through SteamVR or your controller software."
                                   Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16" />
                        <TextBlock Text="VRCHAT CHATBOX" Foreground="{StaticResource Pink}" FontWeight="Bold" FontSize="11" />
                        <CheckBox x:Name="DisableVrChatOscCheckBox" Content="Disable VRChat OSC chatbox sending" Margin="0,7,0,5" />
                        <TextBlock Text="Completed phrases send automatically. The transcript buttons can also send typed text or repeat the visible phrase."
                                   Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16" />
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource PrimaryButton}" Content="Save preferences" Click="SaveSettings_Click" />
                            <Button x:Name="DownloadModelButton" Content="Download base.en model" Click="DownloadModel_Click" />
                        </StackPanel>
                        <Border BorderBrush="#34393D" BorderThickness="0,1,0,0" Margin="0,18,0,14" />
                        <TextBlock Text="APP UPDATES" Foreground="{StaticResource Pink}" FontWeight="Bold" FontSize="11" />
                        <TextBlock x:Name="UpdateStatusText" Text="Check GitHub Releases for app updates." Foreground="{StaticResource Muted}"
                                   TextWrapping="Wrap" Margin="0,5,0,10" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Check updates" Click="CheckUpdates_Click" />
                            <Button x:Name="InstallUpdateButton" Content="Install update" Click="InstallUpdate_Click" IsEnabled="False" />
                            <Button Content="Open releases" Click="OpenReleases_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                </ScrollViewer>
            </Grid>
            <Border Grid.Row="2" Background="#141617" BorderBrush="#272B2E" BorderThickness="0,1,0,0">
                <TextBlock x:Name="FooterStatusText" Text="Ready" Foreground="{StaticResource Muted}" FontSize="11" Margin="12,6" />
            </Border>
        </Grid>
        <Grid Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,18,40" Panel.ZIndex="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#17191B" BorderBrush="{StaticResource Pink}" BorderThickness="1"
                    CornerRadius="8,0,0,8" Padding="14,11" Width="275">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=CreatorOverlayToggle}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Made by Lexi" Foreground="#F4F4F4" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock x:Name="InstalledVersionText" Text="Voxie" Foreground="#7F8A90" FontSize="10" Margin="0,2,0,0" />
                    <TextBlock Foreground="#AEB4B8" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0">
                        <Run Text="Found a bug or have feedback? Join " />
                        <Hyperlink NavigateUri="https://discord.gg/N8JXJqtSbh" RequestNavigate="DiscordLink_RequestNavigate">
                            <Run Text="discord.gg/N8JXJqtSbh" />
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
            <ToggleButton x:Name="CreatorOverlayToggle" Grid.Column="1" Width="58" Height="58" Padding="6"
                          Background="#17191B" BorderBrush="{StaticResource Pink}" BorderThickness="1"
                          ToolTip="Creator and bug reports">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="CreatorButtonChrome" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CreatorButtonChrome" Property="Background" Value="#202326" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CreatorButtonChrome" Property="CornerRadius" Value="0,8,8,0" />
                                <Setter TargetName="CreatorButtonChrome" Property="Background" Value="#202326" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ToggleButton.Template>
                <Image Source="/Assets/CreatorWatermark.png" Stretch="Uniform" Opacity="0.94" />
            </ToggleButton>
        </Grid>
    </Grid>
</Window>
